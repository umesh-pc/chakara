  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="row g-4">
        
        <!-- About Column -->
        <div class="col-lg-4 col-md-6">
          <h4 class="gold-gradient-text mb-3" style="font-weight: 800; font-family: var(--font-serif);">CHAKRA ART INDUSTRIES</h4>
          <p class="text-secondary" style="font-size: 0.85rem; line-height: 1.6;">
            We design, sculpt, paint, and restore premium Christian holy statues, altars, and church figures. Elevating worship spaces with high-quality, elegant, and dedicated craftsmanship.
          </p>
          <div class="social-icons mt-3">
            <a href="https://wa.me/<%= whatsappNum %>" target="_blank" title="Chat on WhatsApp"><i class="fa-brands fa-whatsapp"></i></a>
            <a href="#" title="Instagram"><i class="fa-brands fa-instagram"></i></a>
            <a href="#" title="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
          </div>
        </div>
        
        <!-- Quick Links Column -->
        <div class="col-lg-2 col-md-6">
          <h5>Quick Links</h5>
          <ul class="footer-links">
            <li><a href="/">Home</a></li>
            <li><a href="/about">About Us</a></li>
            <li><a href="/products">Statues & Figures</a></li>
            <li><a href="/gallery">Work Gallery</a></li>
            <li><a href="/contact">Get in Touch</a></li>
            <li><a href="/admin/login" style="font-size: 0.8rem; opacity: 0.7;"><i class="fa-solid fa-lock me-1"></i>Admin Portal</a></li>
          </ul>
        </div>
        
        <!-- Contact details Column -->
        <div class="col-lg-3 col-md-6">
          <h5>Contact Us</h5>
          <ul class="footer-links text-secondary" style="padding-left: 0;">
            <li class="mb-3">
              <i class="fa-solid fa-location-dot text-gold me-2" style="color: var(--primary-gold);"></i>
              <%- address.replace(/\r\n|\n/g, '<br>') %>
            </li>
            <li class="mb-3">
              <i class="fa-solid fa-phone text-gold me-2" style="color: var(--primary-gold);"></i>
              <a href="tel:<%= phoneNum %>"><%= phoneNum %></a>
            </li>
            <li class="mb-3">
              <i class="fa-solid fa-envelope text-gold me-2" style="color: var(--primary-gold);"></i>
              <a href="mailto:<%= emailAddr %>"><%= emailAddr %></a>
            </li>
          </ul>
        </div>
        
        <!-- Google Map Embed Column -->
        <div class="col-lg-3 col-md-6">
          <h5>Location Map</h5>
          <div class="ratio ratio-16x9 border-gold" style="border: 1px solid var(--primary-gold);">
            <iframe 
              src="<%= mapEmbedUrl %>" 
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>
        </div>
        
      </div>
      
      <!-- Footer Copyright -->
      <div class="footer-bottom text-center">
        <p class="mb-0">&copy; <%= currentYear %> Chakra Art Industries. All Rights Reserved. Crafted with dedication.</p>
      </div>
    </div>
  </footer>

  <!-- Bootstrap 5 Bundle JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  
  <!-- Custom JS -->
  <script src="/js/main.js"></script>
</body>
</html>
