<%- include('partials/header') %>

<!-- Auto-Sliding Hero Banner -->
<div id="heroCarousel" class="carousel slide carousel-fade hero-carousel" data-bs-ride="carousel" data-bs-interval="5000">
  <div class="carousel-indicators">
    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
  </div>
  <div class="carousel-inner">
    
    <!-- Slide 1 -->
    <div class="carousel-item active">
      <img src="/images/hero_jesus_statue.png" alt="Jesus Christ Statue - Chakra Art Industries">
      <div class="carousel-caption d-flex flex-column justify-content-center h-100">
        <h1 class="display-3">Sacred Handcrafted Statuary</h1>
        <p>Premium quality Christian statues and figures crafted by master artisans.</p>
        <div>
          <a href="/products" class="btn btn-gold btn-lg me-3">Explore Statues</a>
          <a href="/contact" class="btn btn-outline-light btn-lg" style="border-radius: 0;">Contact Us</a>
        </div>
      </div>
    </div>
    
    <!-- Slide 2 -->
    <div class="carousel-item">
      <img src="/images/hero_mary_statue.png" alt="Virgin Mary Statue - Chakra Art Industries">
      <div class="carousel-caption d-flex flex-column justify-content-center h-100">
        <h1 class="display-3">Devotional Elegance</h1>
        <p>Bringing beauty and spiritual reverence to cathedrals, chapels, and home altars.</p>
        <div>
          <a href="/products" class="btn btn-gold btn-lg me-3">View Collections</a>
          <a href="https://wa.me/<%= whatsappNumber %>" target="_blank" class="btn btn-whatsapp btn-lg"><i class="fa-brands fa-whatsapp me-2"></i>Inquire Now</a>
        </div>
      </div>
    </div>
    
    <!-- Slide 3 -->
    <div class="carousel-item">
      <img src="/images/saint_joseph_statue.png" alt="Saint Joseph Statue - Chakra Art Industries">
      <div class="carousel-caption d-flex flex-column justify-content-center h-100">
        <h1 class="display-3">Meticulous Restorations</h1>
        <p>Restoring sacred figures and statues to their original, vibrant beauty.</p>
        <div>
          <a href="/gallery" class="btn btn-gold btn-lg me-3">Restoration Gallery</a>
          <a href="/restorations" class="btn btn-outline-light btn-lg" style="border-radius: 0;">Restoration Showcase</a>
        </div>
      </div>
    </div>
    
  </div>
  <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
    <span class="visually-hidden">Previous</span>
  </button>
  <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
    <span class="carousel-control-next-icon" aria-hidden="true"></span>
    <span class="visually-hidden">Next</span>
  </button>
</div>

<!-- Category Categories Showcase -->
<section class="container py-5 my-3">
  <div class="text-center mb-5 fade-in-section">
    <span class="text-uppercase text-muted" style="letter-spacing: 2px; font-size: 0.8rem;">Showcasing Our Work</span>
    <h2 class="section-title">Artistic Categories</h2>
    <p class="text-secondary col-md-6 mx-auto mt-2">Discover our specialized segments. We create custom church figures and perform pristine restorations.</p>
  </div>
  
  <div class="row">
    <% categories.forEach(category => { %>
      <div class="col-lg-4 col-md-6 fade-in-section">
        <a href="/products?category=<%= category.slug %>" class="text-decoration-none">
          <div class="category-card">
            <% 
              let catImg = "/images/hero_jesus_statue.png";
              if (category.slug === 'mother-mary-statues') catImg = "/images/hero_mary_statue.png";
              if (category.slug === 'saints') catImg = "/images/saint_joseph_statue.png";
              if (category.slug === 'repainting') catImg = "/images/statue_repainting_work.png";
            %>
            <img src="<%= catImg %>" alt="<%= category.name %>">
            <div class="category-overlay">
              <h3><%= category.name %></h3>
              <p><%= category.description || "Browse high-quality figures and details." %></p>
            </div>
          </div>
        </a>
      </div>
    <% }) %>
  </div>
</section>

<!-- About Preview Section -->
<section class="about-preview py-5 my-5">
  <div class="container py-4">
    <div class="row align-items-center g-5">
      <div class="col-lg-6 fade-in-section">
        <div class="border-frame">
          <img src="/images/statue_repainting_work.png" class="img-fluid w-100" alt="About Chakra Art Industries Workshop" style="object-fit: cover; height: 400px; border: 1px solid var(--primary-gold);">
        </div>
      </div>
      <div class="col-lg-6 fade-in-section">
        <span class="text-uppercase text-gold" style="color: var(--primary-gold); letter-spacing: 2px; font-weight: 600; font-size: 0.85rem;">Dedicated to Sacred Arts</span>
        <h2 class="mt-2 mb-4" style="font-family: var(--font-serif); font-size: 2.2rem;">Crafting Masterpieces of Faith Since 1998</h2>
        <p class="text-secondary mb-3" style="line-height: 1.8;">
          At Chakra Art Industries, we honor traditional Christian art through detailed devotion. Our workshop combines time-tested sculpting techniques with premium fiber and polymarble to create church statues that inspire devotion and withstand the test of time.
        </p>
        <p class="text-secondary mb-4" style="line-height: 1.8;">
          From towering 6ft cathedral altar figures to delicate home shrine pieces, we sculpt, embellish with gold leaf, and restore statues with extreme reverence.
        </p>
        <a href="/about" class="btn btn-burgundy btn-lg">Learn More About Us</a>
      </div>
    </div>
  </div>
</section>

<!-- Featured Products Section -->
<section class="container py-5 my-3">
  <div class="text-center mb-5 fade-in-section">
    <span class="text-uppercase text-muted" style="letter-spacing: 2px; font-size: 0.8rem;">Featured Showcase</span>
    <h2 class="section-title">Masterpieces</h2>
    <p class="text-secondary col-md-6 mx-auto mt-2">A hand-picked selection of our most revered Christian holy statues and detailed repaint works.</p>
  </div>
  
  <div class="row">
    <% if (featuredProducts && featuredProducts.length > 0) { %>
      <% featuredProducts.forEach(product => { %>
        <div class="col-lg-4 col-md-6 fade-in-section">
          <div class="product-card">
            <div class="product-img-wrapper">
              <span class="product-badge">Featured</span>
              <img src="<%= product.images[0] %>" alt="<%= product.productName %>">
            </div>
            <div class="product-body">
              <div class="product-category"><%= product.category.name %></div>
              <h4 class="product-title"><%= product.productName %></h4>
              
              <div class="mb-3">
                <span class="text-muted d-block mb-1" style="font-size: 0.75rem;">Available Sizes:</span>
                <% product.size.forEach(sz => { %>
                  <span class="badge rounded-pill bg-light text-dark border me-1 mb-1" style="font-size: 0.75rem;"><%= sz.value %></span>
                <% }) %>
              </div>
              
              <div class="product-footer d-flex gap-2">
                <a href="/product/<%= product.slug %>" class="btn btn-gold btn-sm flex-grow-1">View Details</a>
                <a href="https://wa.me/<%= whatsappNum %>?text=Hi%2C%20I%20am%20interested%20in%20inquiring%20about%20the%20statue%3A%20<%= encodeURIComponent(product.productName) %>" target="_blank" class="btn btn-whatsapp btn-sm px-3" title="WhatsApp Inquiry"><i class="fa-brands fa-whatsapp"></i></a>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="text-center py-5">
        <p class="text-muted">No featured products available at this time. Please check our full catalog.</p>
        <a href="/products" class="btn btn-gold">View All Products</a>
      </div>
    <% } %>
  </div>
</section>

<!-- Call to Action Section -->
<section class="bg-dark text-white py-5 position-relative border-top border-bottom border-gold" style="border-color: var(--primary-gold) !important; background: linear-gradient(rgba(0,0,0,0.85), rgba(0,0,0,0.85)), url('/images/hero_jesus_statue.png') center/cover fixed;">
  <div class="container py-5 text-center fade-in-section">
    <h2 class="display-5 mb-3" style="font-family: var(--font-serif); font-weight: 700;">Inquire About Custom Statue Carving & Restorations</h2>
    <p class="lead col-md-8 mx-auto text-light-50 mb-4" style="font-weight: 300;">
      Do you need a customized saint statue for your parish or require repair and painting for a weathered cathedral statue? Reach out for a free consult and quote.
    </p>
    <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
      <a href="https://wa.me/<%= whatsappNum %>" target="_blank" class="btn btn-whatsapp btn-lg px-4"><i class="fa-brands fa-whatsapp me-2"></i>WhatsApp Inquiry</a>
      <a href="tel:<%= phoneNum %>" class="btn btn-gold btn-lg px-4"><i class="fa-solid fa-phone me-2"></i>Call <%= phoneNum %></a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
