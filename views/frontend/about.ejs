<%- include('partials/header') %>

<!-- Page Header -->
<section class="bg-dark text-white py-5 position-relative border-bottom border-gold" style="border-color: var(--primary-gold) !important; background: linear-gradient(rgba(26,26,26,0.85), rgba(26,26,26,0.85)), url('/images/saint_joseph_statue.png') center/cover;">
  <div class="container py-5 text-center fade-in-section">
    <span class="text-uppercase text-gold" style="color: var(--primary-gold); letter-spacing: 2px; font-size: 0.85rem;">Honoring Divine Grace</span>
    <h1 class="display-4 mt-2" style="font-weight: 800;">About Chakra Art Industries</h1>
    <p class="lead col-md-6 mx-auto mt-3 text-light-50" style="font-weight: 300; font-size: 1.1rem;">
      Bringing decades of meticulous hand-carving and painting craft to the restoration of sacred church statues.
    </p>
  </div>
</section>

<!-- Our Story Section -->
<section class="container py-5 my-5">
  <div class="row align-items-center g-5">
    <div class="col-lg-6 order-lg-2 fade-in-section">
      <div class="border-frame">
        <img src="/images/hero_mary_statue.png" class="img-fluid w-100" alt="Sculpture Craft" style="object-fit: cover; height: 450px; border: 1px solid var(--primary-gold);">
      </div>
    </div>
    <div class="col-lg-6 order-lg-1 fade-in-section">
      <h2 class="mb-4" style="font-family: var(--font-serif); font-size: 2.2rem; position: relative; padding-bottom: 15px;">
        Our Legacy of Faith & Craft
        <span style="position: absolute; bottom: 0; left: 0; width: 60px; height: 3px; background-color: var(--primary-gold);"></span>
      </h2>
      <p class="text-secondary" style="line-height: 1.8;">
        Chakra Art Industries was founded in Thrissur, Kerala, out of a profound passion for preserving sacred art. Our journey began with small restorations of antique church figurines and grew into a full-scale workshop producing monumental statues for parishes and chapels across the country.
      </p>
      <p class="text-secondary" style="line-height: 1.8;">
        Every piece that leaves our workshop is sculpted with high-density materials, cured against moisture, and painted with premium weatherproof pigments to ensure that the icons can inspire generations of believers.
      </p>
      <p class="text-secondary" style="line-height: 1.8;">
        Our artisans specialize in traditional styles, taking inspiration from classic Italian, Spanish, and Portuguese ecclesiastical sculptures. We work closely with priests, convent administrators, and families to capture the precise facial expressions and symbolic colors for each saint.
      </p>
    </div>
  </div>
</section>

<!-- Values and Principles -->
<section class="py-5 bg-white border-top border-bottom border-gold" style="border-color: rgba(197, 168, 92, 0.2) !important;">
  <div class="container py-4">
    <div class="text-center mb-5 fade-in-section">
      <h2 class="section-title">Why Parishes Choose Us</h2>
    </div>
    
    <div class="row g-4">
      <!-- Quality -->
      <div class="col-md-4 fade-in-section">
        <div class="p-4 text-center border h-100 transition-smooth" style="background-color: var(--bg-warm-cream); border-color: rgba(197, 168, 92, 0.2) !important;">
          <div class="mb-3 text-gold" style="color: var(--primary-gold); font-size: 2.5rem;"><i class="fa-solid fa-gem"></i></div>
          <h4 style="font-family: var(--font-serif); font-weight: 600;">Ecclesiastical Quality</h4>
          <p class="text-secondary mt-3 mb-0" style="font-size: 0.9rem; line-height: 1.6;">
            We employ heavy-cast polyester resins, premium marbles, and wood. Gold details are completed with genuine gold-leaf gilding.
          </p>
        </div>
      </div>
      
      <!-- Reverence -->
      <div class="col-md-4 fade-in-section">
        <div class="p-4 text-center border h-100 transition-smooth" style="background-color: var(--bg-warm-cream); border-color: rgba(197, 168, 92, 0.2) !important;">
          <div class="mb-3 text-gold" style="color: var(--primary-gold); font-size: 2.5rem;"><i class="fa-solid fa-hands-praying"></i></div>
          <h4 style="font-family: var(--font-serif); font-weight: 600;">Spiritual Reverence</h4>
          <p class="text-secondary mt-3 mb-0" style="font-size: 0.9rem; line-height: 1.6;">
            A statue is more than decoration. Our artists approach each face, fold, and attribute with deep reverence, ensuring prayerful expression.
          </p>
        </div>
      </div>
      
      <!-- Customization -->
      <div class="col-md-4 fade-in-section">
        <div class="p-4 text-center border h-100 transition-smooth" style="background-color: var(--bg-warm-cream); border-color: rgba(197, 168, 92, 0.2) !important;">
          <div class="mb-3 text-gold" style="color: var(--primary-gold); font-size: 2.5rem;"><i class="fa-solid fa-brush"></i></div>
          <h4 style="font-family: var(--font-serif); font-weight: 600;">Expert Repainting</h4>
          <p class="text-secondary mt-3 mb-0" style="font-size: 0.9rem; line-height: 1.6;">
            We restore chipped, sun-faded, and cracked statues. We match vintage colors or provide vibrant custom schemes as requested.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- The Restoring Process -->
<section class="container py-5 my-5">
  <div class="row align-items-center g-5">
    <div class="col-lg-6 fade-in-section">
      <div class="border-frame">
        <img src="/images/statue_repainting_work.png" class="img-fluid w-100" alt="Repainting Process" style="object-fit: cover; height: 400px; border: 1px solid var(--primary-gold);">
      </div>
    </div>
    <div class="col-lg-6 fade-in-section">
      <h2 class="mb-4" style="font-family: var(--font-serif); font-size: 2.2rem; position: relative; padding-bottom: 15px;">
        Traditional Restoration Steps
        <span style="position: absolute; bottom: 0; left: 0; width: 60px; height: 3px; background-color: var(--primary-gold);"></span>
      </h2>
      <ul class="list-unstyled text-secondary" style="line-height: 1.8;">
        <li class="mb-3">
          <strong style="color: var(--primary-gold-dark);">1. Surface Stripping:</strong> 
          We carefully remove layers of peeling latex paints accumulated over decades without compromising the underlying sculpted features.
        </li>
        <li class="mb-3">
          <strong style="color: var(--primary-gold-dark);">2. Structuring & Crack Fills:</strong> 
          We reinforce internal iron rods, rebuild missing fingers/nimbuses, and fill cracks using professional non-shrink fillers.
        </li>
        <li class="mb-3">
          <strong style="color: var(--primary-gold-dark);">3. Primer & Undercoats:</strong> 
          A moisture-resistant sealant is applied to prime the surface for high-adhesion fine art paint application.
        </li>
        <li class="mb-3">
          <strong style="color: var(--primary-gold-dark);">4. Detailed Painting & Gilding:</strong> 
          Using fine brushes, our artists render highly realistic skin tones, shadows, and apply high-karat gold leaves to halos.
        </li>
      </ul>
      <a href="/products" class="btn btn-gold mt-3">View Our Catalog</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
