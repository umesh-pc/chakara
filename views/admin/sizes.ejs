<%- include('partials/header') %>

<!-- Alerts -->
<% if (error) { %>
  <div class="alert alert-danger alert-dismissible fade show rounded-1 mb-4" role="alert">
    <i class="fa-solid fa-circle-exclamation me-2"></i><%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<% if (success) { %>
  <div class="alert alert-success alert-dismissible fade show rounded-1 mb-4" role="alert">
    <i class="fa-solid fa-circle-check me-2"></i><%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<div class="row g-4">
  
  <!-- Add Size Form (Left Column) -->
  <div class="col-lg-4">
    <div class="form-card py-4 px-4 h-100">
      <h5 class="mb-4 text-dark" style="font-weight: 700; border-bottom: 1px solid var(--border-color); padding-bottom: 10px;">Add New Size Preset</h5>
      <form action="/admin/sizes" method="POST">
        
        <div class="mb-3">
          <label for="value" class="form-label">Size Value (Height)</label>
          <input type="text" class="form-control rounded-1" id="value" name="value" required placeholder="e.g. 1.5ft or 4ft">
          <div class="form-text text-muted">Include the unit, e.g. 'ft' or 'inches'.</div>
        </div>
        
        <div class="mb-4">
          <label for="description" class="form-label">Description (Optional)</label>
          <textarea class="form-control rounded-1" id="description" name="description" rows="4" placeholder="e.g. Suitable for side altars..."></textarea>
        </div>
        
        <button type="submit" class="btn btn-primary w-100 py-2.5 rounded-1" style="background-color: var(--sidebar-bg); border-color: var(--sidebar-bg); font-weight: 600;">
          <i class="fa-solid fa-plus me-1"></i> Add Size Preset
        </button>
      </form>
    </div>
  </div>
  
  <!-- Sizes Directory (Right Column) -->
  <div class="col-lg-8">
    <div class="table-card h-100 mb-0">
      <div class="card-header-custom py-3 px-4">
        <h5 class="mb-0">Size Presets Directory</h5>
      </div>
      
      <div class="table-responsive">
        <% if (sizes && sizes.length > 0) { %>
          <table class="table admin-table align-middle">
            <thead>
              <tr>
                <th>Size Label</th>
                <th>Description</th>
                <th>Created Date</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% sizes.forEach(sz => { %>
                <tr>
                  <td>
                    <span class="badge bg-secondary-subtle text-secondary border px-3 py-2" style="font-size: 0.85rem;">
                      <i class="fa-solid fa-ruler-vertical me-1 text-gold" style="color: var(--primary-gold);"></i><strong><%= sz.value %></strong>
                    </span>
                  </td>
                  <td class="text-secondary small">
                    <%= sz.description || '-' %>
                  </td>
                  <td class="text-secondary small">
                    <%= new Date(sz.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                  </td>
                  <td>
                    <form action="/admin/sizes/delete/<%= sz._id %>" method="POST" class="delete-confirm-form" data-item-type="size">
                      <button type="submit" class="btn btn-sm btn-outline-danger px-2.5" title="Delete Size">
                        <i class="fa-solid fa-trash-can"></i> Delete
                      </button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } else { %>
          <div class="text-center py-5">
            <p class="text-secondary mb-0">No size presets found. Add one on the left!</p>
          </div>
        <% } %>
      </div>
    </div>
  </div>

</div>

<%- include('partials/footer') %>
