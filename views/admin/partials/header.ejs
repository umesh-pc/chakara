<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard | Chakra Art Industries</title>
  
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  
  <!-- FontAwesome Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  
  <!-- Custom Admin CSS -->
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>

  <div class="admin-wrapper">
    
    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="sidebar-header">
        <h4>CHAKRA <span>ADMIN</span></h4>
      </div>
      <ul class="sidebar-menu">
        <li class="sidebar-item <%= page === 'dashboard' ? 'active' : '' %>">
          <a href="/admin/dashboard">
            <i class="fa-solid fa-gauge"></i> Dashboard
          </a>
        </li>
        <li class="sidebar-item <%= page === 'products' ? 'active' : '' %>">
          <a href="/admin/products">
            <i class="fa-solid fa-church"></i> Products
          </a>
        </li>
        <li class="sidebar-item <%= page === 'categories' ? 'active' : '' %>">
          <a href="/admin/categories">
            <i class="fa-solid fa-tags"></i> Categories
          </a>
        </li>
        <li class="sidebar-item <%= page === 'sizes' ? 'active' : '' %>">
          <a href="/admin/sizes">
            <i class="fa-solid fa-ruler-vertical"></i> Sizes
          </a>
        </li>
        <li class="sidebar-item <%= page === 'gallery' ? 'active' : '' %>">
          <a href="/admin/gallery">
            <i class="fa-solid fa-images"></i> Gallery Showcase
          </a>
        </li>
        <li class="sidebar-item <%= page === 'restorations' ? 'active' : '' %>">
          <a href="/admin/restorations">
            <i class="fa-solid fa-screwdriver-wrench"></i> Restorations
          </a>
        </li>
        <li class="sidebar-item <%= page === 'settings' ? 'active' : '' %>">
          <a href="/admin/settings">
            <i class="fa-solid fa-gear"></i> Settings
          </a>
        </li>
        <li class="sidebar-item mt-5 border-top border-secondary">
          <a href="/" target="_blank">
            <i class="fa-solid fa-globe"></i> View Website
          </a>
        </li>
      </ul>
    </aside>

    <!-- Main Content Area -->
    <div class="admin-content">
      
      <!-- Top Navbar -->
      <nav class="admin-navbar">
        <div class="d-flex align-items-center">
          <h5 class="mb-0 text-dark font-weight-bold">
            <% if (page === 'dashboard') { %>Dashboard Overview<% } %>
            <% if (page === 'products') { %>Product Management<% } %>
            <% if (page === 'categories') { %>Category Management<% } %>
            <% if (page === 'sizes') { %>Size Management<% } %>
            <% if (page === 'gallery') { %>Gallery Management<% } %>
          </h5>
        </div>
        <div class="d-flex align-items-center">
          <span class="text-secondary me-3" style="font-size: 0.9rem;">
            <i class="fa-solid fa-user-tie me-1"></i> Hello, <strong><%= adminUsername %></strong>
          </span>
          <a href="/admin/logout" class="btn btn-outline-danger btn-sm px-3 rounded-1">
            <i class="fa-solid fa-right-from-bracket me-1"></i> Logout
          </a>
        </div>
      </nav>

      <!-- Content Injection Box -->
      <main class="admin-main">
