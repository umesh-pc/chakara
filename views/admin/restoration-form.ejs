<%- include('partials/header') %>

<!-- Form Title and Back button -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0 text-dark" style="font-weight: 700;">
    <%= restoration ? 'Edit Restoration Details' : 'Add New Restoration' %>
  </h4>
  <a href="/admin/restorations" class="btn btn-outline-secondary btn-sm rounded-1">
    <i class="fa-solid fa-arrow-left me-1"></i> Cancel & Return
  </a>
</div>

<!-- Alert Notifications -->
<% if (error) { %>
  <div class="alert alert-danger alert-dismissible fade show rounded-1 mb-4" role="alert">
    <i class="fa-solid fa-circle-exclamation me-2"></i><%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<!-- Restoration Form Card -->
<div class="form-card">
  <form action="<%= restoration ? '/admin/restorations/edit/' + restoration._id : '/admin/restorations/new' %>" method="POST" enctype="multipart/form-data">
    <div class="row g-4">
      
      <!-- Title -->
      <div class="col-md-12">
        <label for="title" class="form-label">Restoration Statue Name / Title</label>
        <input type="text" class="form-control rounded-1" id="title" name="title" value="<%= restoration ? restoration.title : '' %>" required placeholder="e.g. Antique Wooden St. Antony Statue">
      </div>

      <!-- Description -->
      <div class="col-12">
        <label for="description" class="form-label">Restoration Work Details</label>
        <textarea class="form-control rounded-1" id="description" name="description" rows="4" placeholder="Detail the damage before, work done (strip, prime, repaint, gild), and final finishes..."><%= restoration ? restoration.description : '' %></textarea>
      </div>

      <!-- Before Image Upload -->
      <div class="col-md-6">
        <label for="imageBefore" class="form-label">Before Restoration Image (Recommended: 3:4 aspect ratio)</label>
        <input type="file" class="form-control rounded-1" id="imageBefore" name="imageBefore" <%= !restoration ? 'required' : '' %> accept="image/*">
        <% if (restoration) { %>
          <div class="form-text text-muted">Leave empty to keep current image.</div>
        <% } %>
        <div id="previewBefore" class="mt-3">
          <% if (restoration && restoration.imageBefore) { %>
            <img src="<%= restoration.imageBefore %>" class="img-thumbnail" style="max-height: 200px; object-fit: cover;" alt="Before image">
          <% } %>
        </div>
        <div id="before-adjust-container" class="mt-2" style="display: none;">
          <button type="button" id="btn-adjust-before" class="btn btn-outline-primary btn-sm rounded-1">
            <i class="fa-solid fa-crop-simple me-1"></i> Adjust / Center
          </button>
          <span id="badge-before-status" class="badge bg-secondary ms-2">Original</span>
        </div>
      </div>

      <!-- After Image Upload -->
      <div class="col-md-6">
        <label for="imageAfter" class="form-label">After Restoration Image (Recommended: 3:4 aspect ratio)</label>
        <input type="file" class="form-control rounded-1" id="imageAfter" name="imageAfter" <%= !restoration ? 'required' : '' %> accept="image/*">
        <% if (restoration) { %>
          <div class="form-text text-muted">Leave empty to keep current image.</div>
        <% } %>
        <div id="previewAfter" class="mt-3">
          <% if (restoration && restoration.imageAfter) { %>
            <img src="<%= restoration.imageAfter %>" class="img-thumbnail" style="max-height: 200px; object-fit: cover;" alt="After image">
          <% } %>
        </div>
        <div id="after-adjust-container" class="mt-2" style="display: none;">
          <button type="button" id="btn-adjust-after" class="btn btn-outline-primary btn-sm rounded-1">
            <i class="fa-solid fa-crop-simple me-1"></i> Adjust / Center
          </button>
          <span id="badge-after-status" class="badge bg-secondary ms-2">Original</span>
        </div>
      </div>

      <!-- Featured Toggle -->
      <div class="col-12">
        <div class="form-check form-switch p-3 border rounded bg-light-subtle d-inline-block">
          <input class="form-check-input ms-0 me-2" type="checkbox" role="switch" id="featured" name="featured" <%= restoration && restoration.featured ? 'checked' : '' %>>
          <label class="form-check-label fw-semibold text-dark" for="featured">
            Feature this restoration on the public display with priority
          </label>
        </div>
      </div>

      <!-- Submit buttons -->
      <div class="col-12 mt-5">
        <button type="submit" class="btn btn-primary px-4 py-2.5 rounded-1" style="background-color: var(--sidebar-bg); border-color: var(--sidebar-bg); font-weight: 600;">
          <i class="fa-solid fa-cloud-arrow-up me-1"></i> <%= restoration ? 'Update Restoration' : 'Publish Restoration' %>
        </button>
        <a href="/admin/restorations" class="btn btn-outline-secondary px-4 py-2.5 rounded-1 ms-2">
          Cancel
        </a>
      </div>

    </div>
  </form>
</div>

<!-- Cropper.js CSS & JS -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>

<!-- Crop Modal -->
<div class="modal fade" id="cropModal" tabindex="-1" aria-labelledby="cropModalLabel" aria-hidden="true" data-bs-backdrop="static">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content rounded-1">
      <div class="modal-header bg-dark text-white">
        <h5 class="modal-title" id="cropModalLabel">
          <i class="fa-solid fa-crop-simple me-2" style="color: var(--primary-accent);"></i>Adjust & Center Restoration Image
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4 bg-light">
        <p class="text-secondary small mb-3">Drag and resize the crop box to center the statue. The aspect ratio is locked to 3:4 to match the front-end layout.</p>
        <div class="cropper-container-wrapper" style="max-height: 450px; background-color: #000; overflow: hidden; display: flex; justify-content: center; align-items: center; border: 1px solid var(--border-color);">
          <img id="cropper-image" src="" style="max-width: 100%; max-height: 400px; display: block;">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary rounded-1" data-bs-dismiss="modal">Cancel</button>
        <button type="button" id="save-crop-btn" class="btn btn-primary rounded-1" style="background-color: var(--primary-accent); border-color: var(--primary-accent); font-weight: 600;">
          <i class="fa-solid fa-check me-1"></i> Apply Crop
        </button>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const beforeInput = document.getElementById('imageBefore');
  const afterInput = document.getElementById('imageAfter');
  
  const beforeAdjustContainer = document.getElementById('before-adjust-container');
  const afterAdjustContainer = document.getElementById('after-adjust-container');
  
  const btnAdjustBefore = document.getElementById('btn-adjust-before');
  const btnAdjustAfter = document.getElementById('btn-adjust-after');
  
  const badgeBeforeStatus = document.getElementById('badge-before-status');
  const badgeAfterStatus = document.getElementById('badge-after-status');
  
  const previewBefore = document.getElementById('previewBefore');
  const previewAfter = document.getElementById('previewAfter');
  
  const form = beforeInput.closest('form');
  
  let beforeFile = null;
  let afterFile = null;
  
  let croppedBeforeBlob = null;
  let croppedAfterBlob = null;
  
  let currentTarget = ''; // 'before' or 'after'
  let cropperInstance = null;
  const cropModalEl = document.getElementById('cropModal');
  const cropModal = new bootstrap.Modal(cropModalEl);
  const cropperImage = document.getElementById('cropper-image');
  const saveCropBtn = document.getElementById('save-crop-btn');
  
  // File change listeners
  beforeInput.addEventListener('change', function() {
    if (this.files && this.files[0]) {
      beforeFile = this.files[0];
      croppedBeforeBlob = null; // reset crop
      badgeBeforeStatus.textContent = 'Original';
      badgeBeforeStatus.className = 'badge bg-secondary ms-2';
      
      const objectUrl = URL.createObjectURL(beforeFile);
      previewBefore.innerHTML = '<img src="' + objectUrl + '" class="img-thumbnail" style="max-height: 200px; object-fit: cover;" alt="Before image">';
      beforeAdjustContainer.style.display = 'block';
    } else {
      beforeFile = null;
      croppedBeforeBlob = null;
      beforeAdjustContainer.style.display = 'none';
    }
  });
  
  afterInput.addEventListener('change', function() {
    if (this.files && this.files[0]) {
      afterFile = this.files[0];
      croppedAfterBlob = null; // reset crop
      badgeAfterStatus.textContent = 'Original';
      badgeAfterStatus.className = 'badge bg-secondary ms-2';
      
      const objectUrl = URL.createObjectURL(afterFile);
      previewAfter.innerHTML = '<img src="' + objectUrl + '" class="img-thumbnail" style="max-height: 200px; object-fit: cover;" alt="After image">';
      afterAdjustContainer.style.display = 'block';
    } else {
      afterFile = null;
      croppedAfterBlob = null;
      afterAdjustContainer.style.display = 'none';
    }
  });
  
  // Click adjust buttons
  btnAdjustBefore.addEventListener('click', function() {
    currentTarget = 'before';
    const fileToLoad = croppedBeforeBlob ? croppedBeforeBlob : beforeFile;
    cropperImage.src = URL.createObjectURL(fileToLoad);
    cropModal.show();
  });
  
  btnAdjustAfter.addEventListener('click', function() {
    currentTarget = 'after';
    const fileToLoad = croppedAfterBlob ? croppedAfterBlob : afterFile;
    cropperImage.src = URL.createObjectURL(fileToLoad);
    cropModal.show();
  });
  
  cropModalEl.addEventListener('shown.bs.modal', function() {
    if (cropperInstance) {
      cropperInstance.destroy();
    }
    cropperInstance = new Cropper(cropperImage, {
      aspectRatio: 3 / 4,
      viewMode: 1,
      dragMode: 'move',
      autoCropArea: 1,
      background: false,
      responsive: true
    });
  });
  
  cropModalEl.addEventListener('hidden.bs.modal', function() {
    if (cropperInstance) {
      cropperInstance.destroy();
      cropperInstance = null;
    }
    cropperImage.src = '';
  });
  
  saveCropBtn.addEventListener('click', function() {
    if (!cropperInstance) return;
    
    const canvas = cropperInstance.getCroppedCanvas({
      width: 900,
      height: 1200,
      imageSmoothingEnabled: true,
      imageSmoothingQuality: 'high'
    });
    
    canvas.toBlob(function(blob) {
      if (blob) {
        const objectUrl = URL.createObjectURL(blob);
        
        if (currentTarget === 'before') {
          croppedBeforeBlob = blob;
          previewBefore.innerHTML = '<img src="' + objectUrl + '" class="img-thumbnail" style="max-height: 200px; object-fit: cover;" alt="Before image">';
          badgeBeforeStatus.textContent = 'Adjusted / Centered';
          badgeBeforeStatus.className = 'badge bg-success ms-2';
        } else if (currentTarget === 'after') {
          croppedAfterBlob = blob;
          previewAfter.innerHTML = '<img src="' + objectUrl + '" class="img-thumbnail" style="max-height: 200px; object-fit: cover;" alt="After image">';
          badgeAfterStatus.textContent = 'Adjusted / Centered';
          badgeAfterStatus.className = 'badge bg-success ms-2';
        }
        
        cropModal.hide();
      }
    }, 'image/jpeg', 0.9);
  });
  
  // Submit handler
  form.addEventListener('submit', function(e) {
    if (!croppedBeforeBlob && !croppedAfterBlob) return; // Proceed if nothing cropped
    
    e.preventDefault();
    
    // Replace before file
    if (croppedBeforeBlob && beforeFile) {
      const dataTransfer = new DataTransfer();
      const file = new File([croppedBeforeBlob], beforeFile.name, {
        type: 'image/jpeg',
        lastModified: Date.now()
      });
      dataTransfer.items.add(file);
      beforeInput.files = dataTransfer.files;
    }
    
    // Replace after file
    if (croppedAfterBlob && afterFile) {
      const dataTransfer = new DataTransfer();
      const file = new File([croppedAfterBlob], afterFile.name, {
        type: 'image/jpeg',
        lastModified: Date.now()
      });
      dataTransfer.items.add(file);
      afterInput.files = dataTransfer.files;
    }
    
    HTMLFormElement.prototype.submit.call(form);
  });
});
</script>

<%- include('partials/footer') %>
