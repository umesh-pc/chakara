<%- include('partials/header') %>

<!-- Header and Alerts -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0 text-dark" style="font-weight: 700;">Restorations Directory</h4>
  <a href="/admin/restorations/new" class="btn btn-primary rounded-1" style="background-color: var(--sidebar-bg); border-color: var(--sidebar-bg);">
    <i class="fa-solid fa-plus me-1"></i> Add New Restoration
  </a>
</div>

<% if (error) { %>
  <div class="alert alert-danger alert-dismissible fade show rounded-1 mb-4" role="alert">
    <i class="fa-solid fa-circle-exclamation me-2"></i><%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<% if (success) { %>
  <div class="alert alert-success alert-dismissible fade show rounded-1 mb-4" role="alert">
    <i class="fa-solid fa-circle-check me-2"></i><%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<!-- Restorations Table -->
<div class="table-card">
  <div class="table-responsive">
    <% if (restorations && restorations.length > 0) { %>
      <table class="table admin-table align-middle">
        <thead>
          <tr>
            <th>Before Image</th>
            <th>After Image</th>
            <th>Restoration Title</th>
            <th>Featured Status</th>
            <th>Uploaded Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% restorations.forEach(restoration => { %>
            <tr>
              <td>
                <img src="<%= restoration.imageBefore %>" alt="Before restoration" class="rounded animate-hover-scale" style="width: 50px; height: 60px; object-fit: cover; border: 1px solid var(--border-color);">
              </td>
              <td>
                <img src="<%= restoration.imageAfter %>" alt="After restoration" class="rounded animate-hover-scale" style="width: 50px; height: 60px; object-fit: cover; border: 1px solid var(--border-color);">
              </td>
              <td>
                <div class="fw-bold"><%= restoration.title %></div>
                <div class="text-secondary small" style="max-width: 250px; text-overflow: ellipsis; overflow: hidden; white-space: nowrap;">
                  <%= restoration.description || 'No description provided' %>
                </div>
              </td>
              <td>
                <% if (restoration.featured) { %>
                  <span class="badge bg-success-subtle text-success border px-2.5 py-1">Featured</span>
                <% } else { %>
                  <span class="badge bg-light text-secondary border px-2.5 py-1">Standard</span>
                <% } %>
              </td>
              <td class="text-secondary" style="font-size: 0.85rem;">
                <%= new Date(restoration.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
              </td>
              <td>
                <div class="d-flex gap-2">
                  <a href="/admin/restorations/edit/<%= restoration._id %>" class="btn btn-sm btn-outline-secondary px-2.5" title="Edit Restoration">
                    <i class="fa-solid fa-pen-to-square"></i> Edit
                  </a>
                  <form action="/admin/restorations/delete/<%= restoration._id %>" method="POST" class="delete-confirm-form" data-item-type="restoration project">
                    <button type="submit" class="btn btn-sm btn-outline-danger px-2.5" title="Delete Restoration">
                      <i class="fa-solid fa-trash-can"></i> Delete
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <div class="text-center py-5">
        <i class="fa-solid fa-screwdriver-wrench text-muted mb-3" style="font-size: 3rem;"></i>
        <h5 class="text-secondary mb-0">No restoration projects found in database.</h5>
        <p class="text-muted small mt-2">Click "Add New Restoration" to showcase before-after statues.</p>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
