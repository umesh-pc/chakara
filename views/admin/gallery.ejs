<%- include('partials/header') %>

<!-- Alerts -->
<% if (error) { %>
  <div class="alert alert-danger alert-dismissible fade show rounded-1 mb-4" role="alert">
    <i class="fa-solid fa-circle-exclamation me-2"></i><%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<% if (success) { %>
  <div class="alert alert-success alert-dismissible fade show rounded-1 mb-4" role="alert">
    <i class="fa-solid fa-circle-check me-2"></i><%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<div class="row g-4">
  
  <!-- Upload Gallery Image Form (Left Column) -->
  <div class="col-lg-4">
    <div class="form-card py-4 px-4">
      <h5 class="mb-4 text-dark" style="font-weight: 700; border-bottom: 1px solid var(--border-color); padding-bottom: 10px;">Upload Restoration Image</h5>
      <form action="/admin/gallery" method="POST" enctype="multipart/form-data">
        
        <div class="mb-3">
          <label for="title" class="form-label">Image Title</label>
          <input type="text" class="form-control rounded-1" id="title" name="title" required placeholder="e.g. Cathedral Altar Setup">
        </div>
        
        <div class="mb-3">
          <label for="description" class="form-label">Description (Optional)</label>
          <textarea class="form-control rounded-1" id="description" name="description" rows="3" placeholder="Describe the restoration work or statue details..."></textarea>
        </div>
        
        <div class="mb-4">
          <label for="image" class="form-label">Select Image File</label>
          <input type="file" class="form-control rounded-1" id="image" name="image" required accept="image/*">
        </div>
        
        <button type="submit" class="btn btn-primary w-100 py-2.5 rounded-1" style="background-color: var(--sidebar-bg); border-color: var(--sidebar-bg); font-weight: 600;">
          <i class="fa-solid fa-cloud-arrow-up me-1"></i> Upload Image
        </button>
      </form>
    </div>
  </div>
  
  <!-- Gallery Grid (Right Column) -->
  <div class="col-lg-8">
    <div class="table-card h-100 mb-0 py-3 px-4">
      <h5 class="mb-4" style="font-weight: 700; border-bottom: 1px solid var(--border-color); padding-bottom: 10px;">Gallery Directory</h5>
      
      <% if (galleryItems && galleryItems.length > 0) { %>
        <div class="row g-3">
          <% galleryItems.forEach(item => { %>
            <div class="col-sm-6 col-md-4">
              <div class="card h-100 border rounded-1 shadow-sm overflow-hidden position-relative">
                <img src="<%= item.imagePath %>" alt="<%= item.title %>" style="height: 150px; object-fit: cover; width: 100%;">
                
                <div class="card-body p-3">
                  <h6 class="card-title fw-bold mb-1 text-truncate" style="font-size: 0.9rem;"><%= item.title %></h6>
                  <p class="card-text text-secondary small text-truncate mb-3"><%= item.description || 'No description provided' %></p>
                  
                  <form action="/admin/gallery/delete/<%= item._id %>" method="POST" class="delete-confirm-form text-end" data-item-type="gallery item">
                    <button type="submit" class="btn btn-sm btn-outline-danger w-100 py-1.5" style="font-size: 0.8rem;">
                      <i class="fa-solid fa-trash-can me-1"></i> Remove Image
                    </button>
                  </form>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="text-center py-5">
          <i class="fa-regular fa-images text-muted mb-3" style="font-size: 3rem;"></i>
          <p class="text-secondary mb-0">No photos in the gallery. Start by uploading one on the left!</p>
        </div>
      <% } %>
    </div>
  </div>

</div>

<%- include('partials/footer') %>
