<%- include('partials/header') %>

<!-- Form Title and Back button -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0 text-dark" style="font-weight: 700;">
    <%= product ? 'Edit Statue details' : 'Add New Statue' %>
  </h4>
  <a href="/admin/products" class="btn btn-outline-secondary btn-sm rounded-1">
    <i class="fa-solid fa-arrow-left me-1"></i> Cancel & Return
  </a>
</div>

<!-- Alert Notifications -->
<% if (error) { %>
  <div class="alert alert-danger alert-dismissible fade show rounded-1 mb-4" role="alert">
    <i class="fa-solid fa-circle-exclamation me-2"></i><%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<!-- Product Form Card -->
<div class="form-card">
  <form action="<%= product ? '/admin/products/edit/' + product._id : '/admin/products/new' %>" method="POST" enctype="multipart/form-data">
    <div class="row g-4">
      
      <!-- Product Name -->
      <div class="col-md-6">
        <label for="productName" class="form-label">Statue / Figure Name</label>
        <input type="text" class="form-control rounded-1" id="productName" name="productName" value="<%= product ? product.productName : '' %>" required placeholder="e.g. Sacred Heart of Jesus">
      </div>
      
      <!-- Category Selection -->
      <div class="col-md-6">
        <label for="category" class="form-label">Product Category</label>
        <select class="form-select rounded-1" id="category" name="category" required>
          <option value="" disabled <%= !product ? 'selected' : '' %>>Select category...</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat._id %>" <%= product && product.categoryId.toString() === cat._id.toString() ? 'selected' : '' %>><%= cat.name %></option>
          <% }) %>
        </select>
      </div>

      <!-- Size Multi-Select Checkboxes -->
      <div class="col-12">
        <label class="form-label d-block">Available Heights (Select all that apply)</label>
        <div class="p-3 border rounded bg-light">
          <div class="row g-3">
            <% sizes.forEach(sz => { %>
              <% 
                // Check if the current size ID is associated with the product being edited
                let isChecked = false;
                if (product && product.size) {
                  isChecked = product.size.some(ps => ps.toString() === sz._id.toString());
                }
              %>
              <div class="col-6 col-sm-4 col-md-3">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="size" value="<%= sz._id %>" id="size-<%= sz._id %>" <%= isChecked ? 'checked' : '' %>>
                  <label class="form-check-label" for="size-<%= sz._id %>">
                    <%= sz.value %>
                  </label>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      </div>

      <!-- Description -->
      <div class="col-12">
        <label for="description" class="form-label">Product Description & Special Features</label>
        <textarea class="form-control rounded-1" id="description" name="description" rows="5" required placeholder="Provide descriptive details like paint finish type, gold leaf application, carving materials, suitable locations..."><%= product ? product.description : '' %></textarea>
      </div>

      <!-- Multiple Image upload -->
      <div class="col-12">
        <label for="admin-image-input" class="form-label">Upload Images (Upload up to 5 images. Recommended: 4:5 aspect ratio)</label>
        <input type="file" class="form-control rounded-1" id="admin-image-input" name="images" multiple <%= !product ? 'required' : '' %> accept="image/*">
        <% if (product) { %>
          <div class="form-text text-muted">Leave empty to keep existing images. Uploading new images will replace all current images.</div>
        <% } %>
        
        <!-- Live Image Previews -->
        <div id="admin-image-preview" class="image-preview-container mt-3">
          <% if (product && product.images) { %>
            <% product.images.forEach((img, idx) => { %>
              <div class="image-preview-item">
                <img src="<%= img %>" alt="Product Image">
                <% if (idx === 0) { %>
                  <span class="thumbnail-badge">Primary</span>
                <% } %>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>

      <!-- Featured Toggle -->
      <div class="col-12">
        <div class="form-check form-switch p-3 border rounded bg-light-subtle d-inline-block">
          <input class="form-check-input ms-0 me-2" type="checkbox" role="switch" id="featured" name="featured" <%= product && product.featured ? 'checked' : '' %>>
          <label class="form-check-label fw-semibold text-dark" for="featured">
            Feature this product on the home page banner / showcases
          </label>
        </div>
      </div>

      <!-- Submit buttons -->
      <div class="col-12 mt-5">
        <button type="submit" class="btn btn-primary px-4 py-2.5 rounded-1" style="background-color: var(--sidebar-bg); border-color: var(--sidebar-bg); font-weight: 600;">
          <i class="fa-solid fa-cloud-arrow-up me-1"></i> <%= product ? 'Update Product Record' : 'Publish Product Statue' %>
        </button>
        <a href="/admin/products" class="btn btn-outline-secondary px-4 py-2.5 rounded-1 ms-2">
          Cancel
        </a>
      </div>

    </div>
  </form>
</div>

<%- include('partials/footer') %>
